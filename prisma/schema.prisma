generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  passwordHash String        @map("password_hash")
  recoveryCode String?       @map("recovery_code")
  verified     Boolean       @default(false)
  balance      Int           @default(0)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  apiKeys      ApiKey[]
  transactions Transaction[]
  orders       PaymentOrder[]

  @@map("users")
}

model ModelPricing {
  id            String @id @default(uuid())
  model         String @unique
  inputPrice    Int    @map("input_price")
  outputPrice   Int    @map("output_price")
  unit          Int    @default(1000000)

  @@map("model_pricing")
}

model Transaction {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount      Int
  type        String
  description String
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([createdAt])
  @@map("transactions")
}

model ApiKey {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  keyPrefix  String    @map("key_prefix")
  keyHash    String    @map("key_hash")
  totalQuota Int?      @map("total_quota")
  usedQuota  Int       @default(0) @map("used_quota")
  isActive   Boolean   @default(true) @map("is_active")
  expiresAt  DateTime? @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  callLogs   CallLog[]

  @@map("api_keys")
}

model Provider {
  id              String   @id @default(uuid())
  name            String   @unique
  apiKeyEncrypted String   @map("api_key_encrypted")
  baseUrl         String?  @map("base_url")
  isEnabled       Boolean  @default(false) @map("is_enabled")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("providers")
}

model CallLog {
  id             String   @id @default(uuid())
  apiKeyId       String   @map("api_key_id")
  apiKey         ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  provider       String
  model          String
  endpoint       String
  requestTokens  Int      @map("request_tokens")
  responseTokens Int      @map("response_tokens")
  totalTokens    Int      @map("total_tokens")
  latencyMs      Int      @map("latency_ms")
  status         Int
  errorMessage   String?  @map("error_message")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([apiKeyId])
  @@index([createdAt])
  @@map("call_logs")
}

model PaymentOrder {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount        Int
  method        String
  tradeNo       String?  @map("trade_no")
  status        String   @default("pending")
  createdAt     DateTime @default(now()) @map("created_at")
  paidAt        DateTime? @map("paid_at")

  @@index([userId])
  @@index([tradeNo])
  @@map("payment_orders")
}
